{
    "name": "pdfkong/pdfkong-laravel",
    "description": "A simple and clean Laravel package for the PDFKong API.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.0",
        "illuminate/support": "^8.0 || ^9.0 || ^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/http": "^8.0 || ^9.0 || ^10.0 || ^11.0 || ^12.0 || ^13.0"
    },
    "autoload": {
        "psr-4": {
            "PDFKong\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PDFKong\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "orchestra/testbench": "^8.0 || ^9.0",
        "phpunit/phpunit": "^10.0",
        "laravel/pint": "^1.29"
    },
    "extra": {
        "laravel": {
            "providers": [
                "PDFKong\\PDFKongServiceProvider"
            ],
            "aliases": {
                "PDFKong": "PDFKong\\Facades\\PDFKong"
            }
        }
    }
}
